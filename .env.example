# LLM_PROVIDER must be set to 'lmstudio' to use any local OpenAI-compatible server
LLM_PROVIDER=lmstudio

# The model identifier as loaded by llama.cpp (shown via /v1/models endpoint)
# For llama.cpp this is typically the filename of the GGUF file without the path
LLM_STUDIO_MODEL=qwen2.5-coder-7b-instruct-q4_k_m

# Base URL of the local llama.cpp server
LLM_STUDIO_BASE_URL=http://localhost:8080/v1

# Dummy API key — local servers don't require a real key
LLM_STUDIO_API_KEY=not-needed

# Hugging Face Repository to download the model from
HF_REPO=Qwen/Qwen2.5-Coder-7B-Instruct-GGUF

# Specific GGUF file name inside the repository to download and run
HF_FILE=qwen2.5-coder-7b-instruct-q4_k_m.gguf

