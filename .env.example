# =====================================================================
# LLaMEA - Environment Variables Configuration
# Copy this file to `.env` and fill in your values.
# DO NOT commit the `.env` file to version control.
# =====================================================================

# ---------------------------------------------------------------------
# Global Configuration
# ---------------------------------------------------------------------
# Choose the active LLM provider. Supported: 'gemini', 'lmstudio'
LLM_PROVIDER=gemini

# ---------------------------------------------------------------------
# Google Gemini Provider
# ---------------------------------------------------------------------
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------
# LM Studio / OpenAI-Compatible Remote Server
# ---------------------------------------------------------------------
LLM_STUDIO_API_KEY=llm-studio
LLM_STUDIO_MODEL=local-model
LLM_STUDIO_BASE_URL=http://localhost:1234/v1

